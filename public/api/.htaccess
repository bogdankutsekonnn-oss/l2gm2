# Пробрасываем Authorization заголовок в PHP (Timeweb/Apache)
RewriteEngine On
RewriteCond %{HTTP:Authorization} .+
RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

# Запрещаем прямой доступ к config.php, secrets.php и SQL-файлам
<FilesMatch "(config\.php|secrets\.php|\.sql$)">
    Order Allow,Deny
    Deny from all
</FilesMatch>
